# Backend configuration. Copy to .env and adjust.

# --- Branding (display only — the ONLY place the brand name lives) ---
APP_NAME=Notabula
APP_TAGLINE=Your notes, on your server
APP_URL=http://localhost:8200
SUPPORT_EMAIL=hello@example.com

# --- Deployment ---
ENVIRONMENT=development
DEBUG=false

# --- Security ---
# Generate a real one: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me
SESSION_TTL_DAYS=90
# Close registration once everyone you want has an account.
ALLOW_REGISTRATION=true

# --- Datastore (compose overrides this with the in-network service name) ---
DATABASE_URL=postgresql+asyncpg://notesapp:notesapp@localhost:5433/notesapp

# --- Media ---
MEDIA_ROOT=/app/media
MAX_UPLOAD_MB=20

# --- CORS (only needed for the Vite dev server; nginx serves same-origin) ---
CORS_ORIGINS=["http://localhost:5175"]
